# ─────────────────────────────────────────────────────────────
# Polymarket API  (polymarket.com → Settings → API Keys)
# ─────────────────────────────────────────────────────────────
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_SECRET=your_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here
POLYMARKET_WALLET_ADDRESS=0xYourPolygonWalletAddress

# ─────────────────────────────────────────────────────────────
# Polygon wallet private key  (NEVER commit this value)
# ─────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=0xYourPrivateKeyHere

# ─────────────────────────────────────────────────────────────
# Polygon RPC
# ─────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com

# ─────────────────────────────────────────────────────────────
# Telegram  (create bot via @BotFather, get chat ID via @userinfobot)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─────────────────────────────────────────────────────────────
# Strategy parameters  (tune after paper trading)
# ─────────────────────────────────────────────────────────────
EDGE_THRESHOLD=0.07
ENTRY_WINDOW_SECONDS=30
MIN_SECONDS_REMAINING=3
MAX_BET_FRACTION=0.03
KELLY_FRACTION=0.10
TARGET_EDGE_FOR_MAX_SIZE=0.14
MIN_BET_USD=1.00
DAILY_LOSS_CAP=0.05
MIN_MARKET_LIQUIDITY=1500
MAX_CONCURRENT_POSITIONS=2
INITIAL_BANKROLL=300.0

# ─────────────────────────────────────────────────────────────
# Structural-arbitrage runtime
# ─────────────────────────────────────────────────────────────
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_HOST=https://clob.polymarket.com
ARB_POLL_SECONDS=20
# Extra wait after a failed engine cycle (seconds) before the normal poll; reduces tight error loops.
ARB_CYCLE_ERROR_BACKOFF_SECONDS=8
# Gamma REST client total timeout (seconds).
GAMMA_HTTP_TIMEOUT_SECONDS=30
# Max parallel CLOB order-book fetches per cycle (lower if you see throttling).
CLOB_BOOK_FETCH_CONCURRENCY=12
MAX_TRACKED_EVENTS=100
MIN_EVENT_LIQUIDITY=2000
MIN_OUTCOMES_PER_EVENT=2
MIN_COMPLETE_SET_EDGE_BPS=25
MIN_NEG_RISK_EDGE_BPS=40
# Extra edge required on top of each floor to cushion snapshot staleness, your own
# market impact, and fee uncertainty between scan and live fill. Effective minimum
# edge = MIN_*_EDGE_BPS + this. Set 0 only for tests/replay (fills == scanned book).
ARB_SLIPPAGE_BUFFER_BPS=15
MAX_EVENT_EXPOSURE_PCT=0.10
MAX_BASKET_NOTIONAL=50
MAX_TOTAL_OPEN_BASKETS=4

# ─────────────────────────────────────────────────────────────
# Structural-arb improvements
# ─────────────────────────────────────────────────────────────
# Max open baskets per strategy type (complete_set / neg_risk_conversion).
# Prevents all basket slots from being consumed by a single strategy.
MAX_BASKETS_PER_STRATEGY=2
MAX_OPPORTUNITIES_PER_CYCLE=3
OPPORTUNITY_COOLDOWN_SECONDS=300
ALLOW_TAKER_EXECUTION=true
# Category filter for the universe (comma-separated substring matches).
# Leave empty to scan all categories.
CATEGORY_ALLOWLIST=
CATEGORY_BLOCKLIST=

# ─────────────────────────────────────────────────────────────
# Real-time streaming  (the latency edge — react in ms, not on a poll)
# ─────────────────────────────────────────────────────────────
# true: maintain a live order-book cache over the CLOB market WebSocket and
# re-scan an event the instant one of its books changes (places trades before
# pollers). false: fall back to the legacy ARB_POLL_SECONDS REST loop.
ARB_STREAMING_ENABLED=true
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
# How often to refresh the Gamma universe + resubscribe, and run a full REST
# reconcile (books stream continuously between these).
ARB_UNIVERSE_REFRESH_SECONDS=30
# A streamed book older than this (seconds, no update received) is treated as
# stale and excluded from scanning so a frozen quote is never traded.
ARB_BOOK_STALENESS_SECONDS=6
# Coalesce a burst of book updates for one event before re-scanning (ms).
# 0 = scan on every delta (lowest latency, more CPU).
ARB_HOT_SCAN_DEBOUNCE_MS=15
# Cap on simultaneous token subscriptions (2 tokens per market).
ARB_MAX_BOOK_SUBSCRIPTIONS=1200
ARB_WS_RECONNECT_MAX_SECONDS=10

# ─────────────────────────────────────────────────────────────
# Live execution  (REAL money — OFF by default, multiple hard gates)
# ─────────────────────────────────────────────────────────────
# Real orders are POSTed only when ALL of these hold: PAPER_TRADE=false,
# ENABLE_LIVE_EXECUTION=true, LIVE_DRY_RUN=false, and all live secrets above are
# set. Any gate unmet keeps you on the simulated exchange; LIVE_DRY_RUN exercises
# the full live path (build + sign + log the exact order) without sending it.
ENABLE_LIVE_EXECUTION=false
LIVE_DRY_RUN=true
# Hard ceiling on a single live order's USDC notional (last-line fat-finger cap).
LIVE_MAX_ORDER_USDC=25
# py-clob-client signature type (2 = Polymarket proxy/email wallet).
CLOB_SIGNATURE_TYPE=2

# ─────────────────────────────────────────────────────────────
# Paper trading realism
# ─────────────────────────────────────────────────────────────
# Taker fee assumption (bps) when Gamma marks fees_enabled; default in Settings is 50 (0.5%). Tune to match Polymarket.
PAPER_TAKER_FEE_BPS=50
PAPER_MAKER_REBATE_BPS=0.0
# Extra buy-side cost per fill (bps) to simulate spread on thin/synthetic books.
# Set to 15-20 for conservative pre-live validation. 0 = disabled.
PAPER_SPREAD_PENALTY_BPS=0
AUTO_SETTLE_RESOLVED_EVENTS=true
REPLAY_OUTPUT_DIR=data/replays

# ─────────────────────────────────────────────────────────────
# System
# ─────────────────────────────────────────────────────────────
CONTROL_API_PORT=8765
CONTROL_API_TOKEN=
LOG_LEVEL=INFO

# true = paper mode (recommended default). The structural-arb engine simulates
# fills on the in-repo exchange. Setting false ALONE does not place real orders:
# real execution additionally requires ENABLE_LIVE_EXECUTION=true, LIVE_DRY_RUN=false
# and all live secrets (see the Live execution section above and README).
PAPER_TRADE=true

# Conservative defaults for a few-hundred-dollar bankroll.
# Manual asset flags below are legacy directional settings retained for optional sidecars.
STRATEGY_PROFILE=conservative
AUTO_ASSET_SELECTION=true

# ─────────────────────────────────────────────────────────────
# Legacy multi-asset directional control
# ─────────────────────────────────────────────────────────────
TRADE_BTC=true
TRADE_ETH=true
TRADE_SOL=true
TRADE_XRP=true
TRADE_ADA=false
TRADE_DOGE=false
TRADE_AVAX=false
TRADE_LINK=false

# ─────────────────────────────────────────────────────────────
# Maker order tuning
# ─────────────────────────────────────────────────────────────
MAX_REPOSTS_PER_WINDOW=4
REPOST_STALE_TICKS=2
CANCEL_AT_SECONDS_REMAINING=6
MAX_MAKER_AGGRESSION_TICKS=3
MAKER_REBATE_BPS_ASSUMPTION=0.0

# ─────────────────────────────────────────────────────────────
# Multi-asset risk
# ─────────────────────────────────────────────────────────────
MAX_POSITIONS_PER_ASSET=1
MAX_TOTAL_EXPOSURE_PCT=0.40
