# ─────────────────────────────────────────────────────────────
# Polymarket CLOB L2 API  (Settings → API Keys, or derive — see below)
# ─────────────────────────────────────────────────────────────
# If all three are empty but WALLET_PRIVATE_KEY is set, the bot derives L2 creds at runtime
# (same as: python scripts/derive_polymarket_api_creds.py). You can still paste POLYMARKET_* here.
POLYMARKET_API_KEY=
POLYMARKET_SECRET=
POLYMARKET_PASSPHRASE=
# Public Polygon address: 0x + 40 hex chars (same account as the key below).
POLYMARKET_WALLET_ADDRESS=

# Relayer UI keys (Settings → Relayer API Keys) — stored for reference; not a substitute for L2 creds above.
RELAYER_API_KEY=
RELAYER_SIGNER_ADDRESS=

# Builder Program (optional): all three required to attach builder headers. Not the same as Relayer-only keys.
BUILDER_API_KEY=
BUILDER_SECRET=
BUILDER_PASSPHRASE=

# ─────────────────────────────────────────────────────────────
# Polygon wallet private key  (NEVER commit this value)
# ─────────────────────────────────────────────────────────────
# 64 hex digits, optional 0x prefix. Leave empty until you copy a real key into .env locally.
WALLET_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────────
# Polygon RPC
# ─────────────────────────────────────────────────────────────
# Optional: HTTPS Polygon RPC for on-chain calls (approvals, neg-risk). Use your own provider in
# local .env if needed; never commit API keys. If unset, Settings uses a documented public default.
# POLYGON_RPC_URL=https://polygon-bor.publicnode.com

# ─────────────────────────────────────────────────────────────
# Telegram  (create bot via @BotFather, get chat ID via @userinfobot)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────
# Strategy parameters  (tune after paper trading)
# ─────────────────────────────────────────────────────────────
EDGE_THRESHOLD=0.07
ENTRY_WINDOW_SECONDS=30
MIN_SECONDS_REMAINING=3
MAX_BET_FRACTION=0.03
KELLY_FRACTION=0.10
TARGET_EDGE_FOR_MAX_SIZE=0.14
MIN_BET_USD=1.00
DAILY_LOSS_CAP=0.05
MIN_MARKET_LIQUIDITY=1500
MAX_CONCURRENT_POSITIONS=2
INITIAL_BANKROLL=300.0

# ─────────────────────────────────────────────────────────────
# Structural-arbitrage runtime
# ─────────────────────────────────────────────────────────────
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_HOST=https://clob.polymarket.com
# Order signing: 0=EOA, 1=Magic/PolyProxy, 2=Gnosis Safe (typical Polymarket.com wallet).
CLOB_SIGNATURE_TYPE=2
ARB_POLL_SECONDS=20
# Extra wait after a failed engine cycle (seconds) before the normal poll; reduces tight error loops.
ARB_CYCLE_ERROR_BACKOFF_SECONDS=8
# Gamma REST client total timeout (seconds).
GAMMA_HTTP_TIMEOUT_SECONDS=60
# Max parallel CLOB order-book fetches per cycle (lower if you see throttling).
CLOB_BOOK_FETCH_CONCURRENCY=24
# Retries when get_order_book fails (0 = no retries).
CLOB_BOOK_RETRY_ATTEMPTS=2
CLOB_BOOK_RETRY_DELAY_SECONDS=0.35
# After building from paginated Gamma data, keep this many events (CLOB books per cycle).
MAX_TRACKED_EVENTS=300
# Gamma pagination: page size × max pages ≈ upper bound on rows fetched (stops early if a page is short/empty).
GAMMA_EVENT_PAGE_SIZE=150
GAMMA_EVENT_MAX_PAGES=25
GAMMA_MARKET_PAGE_SIZE=500
GAMMA_MARKET_MAX_PAGES=40
MIN_EVENT_LIQUIDITY=2000
MIN_OUTCOMES_PER_EVENT=2
MIN_COMPLETE_SET_EDGE_BPS=25
MIN_NEG_RISK_EDGE_BPS=40
# Per-event exposure cap (fraction of max(equity, contributed)). Keep ≥ basket_notional / bankroll.
MAX_EVENT_EXPOSURE_PCT=0.22
MAX_BASKET_NOTIONAL=50
# Share of bankroll per basket cap: min(bankroll × fraction, MAX_BASKET_NOTIONAL). Bankroll = max(equity, contributed, available).
# 0 = use MAX_BASKET_NOTIONAL only. After redeems, CLOB sync raises equity → larger baskets (until ceiling).
# ARB_BASKET_NOTIONAL_FRACTION_OF_EQUITY=0.30
# ARB_BASKET_NOTIONAL_MIN_USD=5
# When >1: if a probe scan at MAX_BASKET_NOTIONAL finds ≥1 qualified opportunity, rescan with basket cap
# = min(MAX_BASKET_NOTIONAL × multiplier, ABS_MAX if ABS_MAX>0). Still bounded by cash & MAX_EVENT_EXPOSURE_PCT.
# ARB_MAX_BASKET_NOTIONAL_QUALIFIED_MULTIPLIER=1.0
# ARB_MAX_BASKET_NOTIONAL_QUALIFIED_ABS_MAX=0
# Live: pull CLOB collateral into the ledger each cycle so redeems/deposits on Polymarket.com show up.
# ARB_SYNC_CLOB_COLLATERAL_EACH_CYCLE=true
# Re-fetch CLOB balance on /summary if older than this (seconds). 0 = only refresh each arb cycle.
# ARB_SUMMARY_CLOB_STALE_SECONDS=5
MAX_TOTAL_OPEN_BASKETS=4

# ─────────────────────────────────────────────────────────────
# Structural-arb improvements
# ─────────────────────────────────────────────────────────────
# Max open baskets per strategy type (complete_set / neg_risk_conversion).
# Prevents all basket slots from being consumed by a single strategy.
MAX_BASKETS_PER_STRATEGY=2
MAX_OPPORTUNITIES_PER_CYCLE=3
OPPORTUNITY_COOLDOWN_SECONDS=300
# 0 = off. Skip arb legs if (ask−bid)/mid exceeds this (bps) — cuts illiquid/wide CLOB quotes.
MAX_ARB_LEG_SPREAD_BPS=750
# 0 = off. Minimum scanner expected profit (USD) after modeled taker fees.
ARB_MIN_EXPECTED_PROFIT_USD=0.25
# 0 = off. If a cycle has this many synthetic books, skip new executions (CLOB degraded).
ARB_HALT_EXECUTION_IF_SYNTHETIC_BOOKS_GE=6
# 0 = off. Halt if mark-to-market equity falls this fraction below the session peak (resume re-anchors peak).
# ARB_TRAILING_EQUITY_DRAWDOWN_PCT=0.12
# 0 = off. Halt if realized PnL vs process start drops by more than this USD.
# ARB_SESSION_REALIZED_LOSS_USD=40
# 0 = off. Halt after this many failed basket executions in a row.
ARB_CONSECUTIVE_EXECUTION_FAILURES_HALT=3
ALLOW_TAKER_EXECUTION=true
# Category filter for the universe (comma-separated substring matches).
# Leave empty to scan all categories.
CATEGORY_ALLOWLIST=
CATEGORY_BLOCKLIST=
# Prefer neg-risk-eligible events when ranking (then by liquidity).
UNIVERSE_PREFER_NEG_RISK=true
# 0 = off. Upper / lower bound on hours until event endDate for universe inclusion.
UNIVERSE_MAX_HOURS_TO_RESOLUTION=0
UNIVERSE_MIN_HOURS_TO_RESOLUTION=0
# Tie-break when trimming to MAX_TRACKED_EVENTS: prefer sooner endDate (faster capital return).
UNIVERSE_PREFER_SHORTER_RESOLUTION=false
# Log per-cycle scanner diagnostics (near-miss edges) at INFO.
ARB_LOG_CYCLE_DIAGNOSTICS=true

# Optional second sleeve (paper): directional overlay using same news + crypto signals as the
# backtest predictors. Runs only on real CLOB books, capped size, and by default only when
# this cycle had zero structural-arb opportunities and zero arb fills.
# ENABLE_DIRECTIONAL_OVERLAY=false
# DIRECTIONAL_OVERLAY_EVERY_N_CYCLES=3
# DIRECTIONAL_OVERLAY_ONLY_WHEN_NO_ARB=true
# DIRECTIONAL_OVERLAY_MIN_EDGE=0.10
# DIRECTIONAL_OVERLAY_MAX_NOTIONAL=12
# DIRECTIONAL_OVERLAY_MAX_SPREAD=0.12
# DIRECTIONAL_OVERLAY_CASH_FLOOR=75
# DIRECTIONAL_OVERLAY_LLM_NEWS=false
# DIRECTIONAL_OVERLAY_SHRINK_WEIGHT=0.28

# Optional: mirror public trades from Polymarket Data API leaderboard wallets (scaled, universe-matched).
# Not arbitrage; live copies need TRADER_FOLLOW_ALLOW_LIVE=true and ARB_LIVE_EXECUTION.
# ENABLE_TRADER_FOLLOW=false
# TRADER_FOLLOW_ALLOW_LIVE=false
# TRADER_FOLLOW_TOP_WALLETS=8
# TRADER_FOLLOW_TIME_PERIOD=WEEK
# TRADER_FOLLOW_WALLETS_EXTRA=

# ─────────────────────────────────────────────────────────────
# Paper trading realism
# ─────────────────────────────────────────────────────────────
# Taker fee assumption (bps) when Gamma marks fees_enabled; default in Settings is 50 (0.5%). Tune to match Polymarket.
PAPER_TAKER_FEE_BPS=50
PAPER_MAKER_REBATE_BPS=0.0
# Extra BUY-side cost per fill (bps). Same formula in scanner + PaperExchange. 0 = fee-only (tests).
PAPER_SPREAD_PENALTY_BPS=15
AUTO_SETTLE_RESOLVED_EVENTS=true
# Complete-set exit: FAK-sell all YES legs when triggers fire (converts to USDC on CLOB).
COMPLETE_SET_AUTO_UNWIND=true
# If true, sell only when net CLOB proceeds (after fees) >= holding to resolution ($1/share) minus epsilon.
COMPLETE_SET_UNWIND_VS_RESOLUTION=true
COMPLETE_SET_UNWIND_VS_RESOLUTION_EPSILON_USD=0.03
# If VS_RESOLUTION=false, legacy OR triggers below apply.
# Sum of best bids across YES legs; >= 0.993 means ~$1/set recoverable before fees.
COMPLETE_SET_UNWIND_MIN_BID_SUM=0.993
# Profit/gross triggers: allow slightly negative estimated net (fee rounding) or 0.0 for strict.
COMPLETE_SET_UNWIND_MIN_EST_NET_USD=0.0
# Force unwind if estimated loss vs cost reaches this many bps (0 = off).
COMPLETE_SET_UNWIND_STOP_LOSS_BPS=0
# Unwind when estimated net sell vs cost >= this USD (0 = off). Easier exit than MIN_PROFIT_BPS alone.
COMPLETE_SET_UNWIND_MIN_ANY_PROFIT_USD=0
# Log why a complete set is held (seconds between identical reason lines per basket); 0 = off.
ARB_LOG_COMPLETE_SET_HOLD_INTERVAL_SECONDS=0
# Also exit if estimated net sell PnL vs cost >= this many bps (0 = disable this trigger).
COMPLETE_SET_UNWIND_MIN_PROFIT_BPS=75
# Gross (pre-fee) bid recovery vs cost; exit when book beats entry even if sum(bids) < $1.
COMPLETE_SET_UNWIND_MIN_GROSS_RECOVERY_BPS=35
REPLAY_OUTPUT_DIR=data/replays

# ─────────────────────────────────────────────────────────────
# System
# ─────────────────────────────────────────────────────────────
# Multi-agent: set a unique SQLite path + port per process (see scripts/run_two_structural_agents.py).
# ARB_SQLITE_PATH=
# AGENT_DISPLAY_NAME=
CONTROL_API_PORT=8765
CONTROL_API_TOKEN=
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# LLM advisor (python -m agents.advisor_app, port ADVISOR_PORT)
# ─────────────────────────────────────────────────────────────
# Local Ollama (free): ollama serve && ollama pull llama3.2
# For advisor + Ollama (optional): copy these lines into your real .env
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2
# OpenAI-compatible (Groq / OpenRouter / OpenAI, etc.):
# LLM_PROVIDER=openai_compatible
# OPENAI_API_BASE=https://api.openai.com/v1
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# ADVISOR_HOST=127.0.0.1
# ADVISOR_PORT=8780
# ADVISOR_HTTP_TIMEOUT=120
# ADVICE_CACHE_SECONDS=90
# AGENT_A_PORT=8765
# AGENT_B_PORT=8767

# true = paper mode (recommended). false = live wallet/API secrets required (see README).
PAPER_TRADE=true
# Structural arb: real Polymarket CLOB orders (FOK taker) when PAPER_TRADE=false,
# ALLOW_TAKER_EXECUTION=true, wallet + L2 API creds (or derive). On-chain neg-risk conversion
# needs POLYGON_RPC_URL + native MATIC for gas; live engine may gate neg-risk — see README.
ARB_LIVE_EXECUTION=false
# Per-cycle JSONL of summary + last_cycle (equity, opportunities, executed). Empty path disables.
PAPER_EQUITY_SNAPSHOT_LOG=true
PAPER_EQUITY_LOG_PATH=data/paper_tracking/equity.jsonl

# Conservative defaults for a few-hundred-dollar bankroll.
# Manual asset flags below are legacy directional settings retained for optional sidecars.
STRATEGY_PROFILE=conservative
AUTO_ASSET_SELECTION=true

# ─────────────────────────────────────────────────────────────
# Legacy multi-asset directional control
# ─────────────────────────────────────────────────────────────
TRADE_BTC=true
TRADE_ETH=true
TRADE_SOL=true
TRADE_XRP=true
TRADE_ADA=false
TRADE_DOGE=false
TRADE_AVAX=false
TRADE_LINK=false

# ─────────────────────────────────────────────────────────────
# Maker order tuning
# ─────────────────────────────────────────────────────────────
MAX_REPOSTS_PER_WINDOW=4
REPOST_STALE_TICKS=2
CANCEL_AT_SECONDS_REMAINING=6
MAX_MAKER_AGGRESSION_TICKS=3
MAKER_REBATE_BPS_ASSUMPTION=0.0

# ─────────────────────────────────────────────────────────────
# Multi-asset risk
# ─────────────────────────────────────────────────────────────
MAX_POSITIONS_PER_ASSET=1
MAX_TOTAL_EXPOSURE_PCT=0.40
