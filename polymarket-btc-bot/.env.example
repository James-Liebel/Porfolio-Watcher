# ─────────────────────────────────────────────────────────────
# Polymarket API  (polymarket.com → Settings → API Keys)
# ─────────────────────────────────────────────────────────────
POLYMARKET_API_KEY=your_api_key_here
POLYMARKET_SECRET=your_secret_here
POLYMARKET_PASSPHRASE=your_passphrase_here
POLYMARKET_WALLET_ADDRESS=0xYourPolygonWalletAddress

# ─────────────────────────────────────────────────────────────
# Polygon wallet private key  (NEVER commit this value)
# ─────────────────────────────────────────────────────────────
WALLET_PRIVATE_KEY=0xYourPrivateKeyHere

# ─────────────────────────────────────────────────────────────
# Polygon RPC
# ─────────────────────────────────────────────────────────────
POLYGON_RPC_URL=https://polygon-rpc.com

# ─────────────────────────────────────────────────────────────
# Telegram  (create bot via @BotFather, get chat ID via @userinfobot)
# ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# ─────────────────────────────────────────────────────────────
# Strategy parameters  (tune after paper trading)
# ─────────────────────────────────────────────────────────────
EDGE_THRESHOLD=0.07
ENTRY_WINDOW_SECONDS=30
MIN_SECONDS_REMAINING=3
MAX_BET_FRACTION=0.03
KELLY_FRACTION=0.10
TARGET_EDGE_FOR_MAX_SIZE=0.14
MIN_BET_USD=1.00
DAILY_LOSS_CAP=0.05
MIN_MARKET_LIQUIDITY=1500
MAX_CONCURRENT_POSITIONS=2
INITIAL_BANKROLL=300.0

# ─────────────────────────────────────────────────────────────
# Structural-arbitrage runtime
# ─────────────────────────────────────────────────────────────
GAMMA_BASE_URL=https://gamma-api.polymarket.com
CLOB_HOST=https://clob.polymarket.com
ARB_POLL_SECONDS=20
MAX_TRACKED_EVENTS=100
MIN_EVENT_LIQUIDITY=2000
MIN_OUTCOMES_PER_EVENT=2
MIN_COMPLETE_SET_EDGE_BPS=25
MIN_NEG_RISK_EDGE_BPS=40
MAX_EVENT_EXPOSURE_PCT=0.10
MAX_BASKET_NOTIONAL=50
MAX_TOTAL_OPEN_BASKETS=4
MAX_OPPORTUNITIES_PER_CYCLE=3
OPPORTUNITY_COOLDOWN_SECONDS=300
ALLOW_TAKER_EXECUTION=true
PAPER_TAKER_FEE_BPS=0.0
PAPER_MAKER_REBATE_BPS=0.0
AUTO_SETTLE_RESOLVED_EVENTS=true
REPLAY_OUTPUT_DIR=data/replays

# ─────────────────────────────────────────────────────────────
# System
# ─────────────────────────────────────────────────────────────
CONTROL_API_PORT=8765
CONTROL_API_TOKEN=
LOG_LEVEL=INFO

# Set to true to shadow live maker orders against the public CLOB book
PAPER_TRADE=true

# Conservative defaults for a few-hundred-dollar bankroll.
# Manual asset flags below are legacy directional settings retained for optional sidecars.
STRATEGY_PROFILE=conservative
AUTO_ASSET_SELECTION=true

# ─────────────────────────────────────────────────────────────
# Legacy multi-asset directional control
# ─────────────────────────────────────────────────────────────
TRADE_BTC=true
TRADE_ETH=true
TRADE_SOL=true
TRADE_XRP=true
TRADE_ADA=false
TRADE_DOGE=false
TRADE_AVAX=false
TRADE_LINK=false

# ─────────────────────────────────────────────────────────────
# Maker order tuning
# ─────────────────────────────────────────────────────────────
MAX_REPOSTS_PER_WINDOW=4
REPOST_STALE_TICKS=2
CANCEL_AT_SECONDS_REMAINING=6
MAX_MAKER_AGGRESSION_TICKS=3
MAKER_REBATE_BPS_ASSUMPTION=0.0

# ─────────────────────────────────────────────────────────────
# Multi-asset risk
# ─────────────────────────────────────────────────────────────
MAX_POSITIONS_PER_ASSET=1
MAX_TOTAL_EXPOSURE_PCT=0.40
